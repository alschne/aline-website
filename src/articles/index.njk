---
layout: base.njk
title: Articles
description: Insights on compensation, hiring, and people strategy.
permalink: /articles/index.html
---

<div class="page-hero">
  <div class="page-hero-text">
    <h1>Articles</h1>
    <h3>Insights on compensation, hiring, and people strategy</h3>
  </div>
  <div class="page-hero-img" style="background-image: url('/images/articles_page.png')"></div>
</div>

<section class="articles-container">

  <div class="articles-meta">
    <span class="articles-count">{{ collections.articles | length }} article{% if collections.articles | length != 1 %}s{% endif %}</span>
  </div>

  <div class="articles-grid">
    {% for post in collections.articles %}
    <a class="article-card" href="{{ post.url }}">
      {% if post.data.image %}
      <img class="article-card-img" src="{{ post.data.image }}" alt="{{ post.data.title }}">
      {% endif %}
      <div class="article-card-body">
        <span class="article-card-date">{{ post.date | dateReadable }}</span>
        <h2 class="article-card-title">{{ post.data.title }}</h2>
        <div class="article-card-footer">
          <span class="article-card-read">Read article <i class="fa-solid fa-arrow-right"></i></span>
        </div>
      </div>
    </a>
    {% endfor %}
  </div>

</section>
